# FairDraw Protocol Environment Variables

# Application
VITE_APP_URL=https://fairdraw.vistara.dev
VITE_APP_NAME=FairDraw Protocol

# Blockchain Configuration
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
PRIVATE_KEY=your_private_key_here
BASESCAN_API_KEY=your_basescan_api_key_here

# Chainlink VRF
VRF_SUBSCRIPTION_ID=1
VRF_COORDINATOR_BASE=0xd5D517aBE5cF79B7e95eC98dB0f0277788aFF634

# Database (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# API Configuration
PORT=3001
NODE_ENV=production

# Payment Integration
VISTARA_PAYMENTS_URL=https://payments.vistara.dev

# Farcaster Integration
FARCASTER_HUB_URL=https://hub.farcaster.xyz
FARCASTER_APP_FID=your_app_fid

# Security
JWT_SECRET=your_jwt_secret_here
CORS_ORIGIN=https://fairdraw.vistara.dev

# Monitoring & Analytics
SENTRY_DSN=your_sentry_dsn
ANALYTICS_ID=your_analytics_id

# Feature Flags
ENABLE_FRAMES=true
ENABLE_SOCIAL_SHARING=true
ENABLE_NOTIFICATIONS=true
